---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = "" } = Astro.props;
const base =
  "inline-flex items-center rounded-[4px] bg-(--color-bg-subtle) px-2.5 py-1 text-[12px] font-medium text-(--color-text-secondary) transition-colors";
const hover = href
  ? "hover:bg-(--color-accent-subtle) hover:text-(--color-accent)"
  : "";
---

{
  href ? (
    <a href={href} class:list={[base, hover, className]}>
      <slot />
    </a>
  ) : (
    <span class:list={[base, className]}>
      <slot />
    </span>
  )
}
