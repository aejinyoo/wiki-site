---
import { getWikiItems, getDailyEntries } from "../lib/collections";

const items = await getWikiItems();
const daily = await getDailyEntries();
const updatedAt = new Date().toISOString().slice(0, 10);
---

<footer class="mt-24 border-t border-(--color-border) py-10">
  <div class="mx-auto max-w-[1080px] px-5 md:px-8">
    <div class="flex flex-col gap-3 text-[13px] text-(--color-text-secondary) md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-3">
        <span>아이템 {items.length} · 브리프 {daily.length}</span>
      </div>
      <div class="flex items-center gap-4 text-[13px]">
        <a href="/about" class="text-(--color-text-secondary) hover:text-(--color-accent)">about</a>
        <a href="/rss.xml" class="text-(--color-text-secondary) hover:text-(--color-accent)">rss</a>
        <span class="text-(--color-text-muted)">최종 업데이트 {updatedAt}</span>
      </div>
    </div>
  </div>
</footer>
