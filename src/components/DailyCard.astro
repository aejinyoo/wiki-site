---
import type { DailyEntry } from "../lib/collections";
import { dateFromEntry } from "../lib/collections";
import Card from "./Card.astro";
import { formatDateKorean } from "../lib/dates";
import { briefPreview } from "../lib/daily-content";

interface Props {
  entry: DailyEntry;
  large?: boolean;
}
const { entry, large = false } = Astro.props;
const date = dateFromEntry(entry);
const href = `/daily/${date}`;
const preview = briefPreview(entry.body ?? "");
---

<Card href={href}>
  <div class="flex flex-col gap-3">
    <div class="text-[12px] uppercase tracking-wider text-(--color-text-muted)">
      {large ? "Today's brief" : "Brief"}
    </div>
    <h3 class:list={[
      "font-semibold leading-tight tracking-tight text-(--color-text)",
      large ? "text-[28px]" : "text-[18px]",
    ]}>
      {formatDateKorean(date)}
    </h3>
    {preview && (
      <p class:list={[
        "text-(--color-text-secondary) leading-relaxed",
        large ? "text-[15px] line-clamp-3" : "text-[13px] line-clamp-2",
      ]}>
        {preview}
      </p>
    )}
    <div class="text-[13px] font-medium text-(--color-accent) pt-1">
      읽기 →
    </div>
  </div>
</Card>
